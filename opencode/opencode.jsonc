{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "engram": {
      "command": [
        "/home/neutry/go/bin/engram",
        "mcp",
        "--tools=agent"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "permission": {
    "external_directory": {
      "~/.config/opencode/**": "allow"
    }
  }
}